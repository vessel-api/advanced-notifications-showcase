# Base URL for the VesselAPI notifications REST API. Override only if
# pointing at a non-production cluster.
VESSELAPI_BASE=https://api.vesselapi.com/v1

# Base URL for the VesselAPI notifications WebSocket endpoints. Usually the
# same host as VESSELAPI_BASE but on wss://. Derived from VESSELAPI_BASE if
# left unset.
VESSELAPI_WS_BASE=wss://api.vesselapi.com/v1

# Local port the demo UI listens on.
PORT=3001

# The API key is entered through the UI at runtime and held only in memory
# for the session — it is deliberately NOT an env var so the container image
# can be distributed without risking a committed credential.
